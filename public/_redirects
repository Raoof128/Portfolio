# Redirect public /en/* back to clean English URLs
/en /  302
/en/* /:splat  302

# Catch-all: rewrite any path without a direct file match to /en/
# This covers HTML pages, RSC __next.* prefetch files, and all sub-routes.
# Cloudflare Pages serves actual files (/_next/static/, /fa/*, /ar/*, etc.)
# directly BEFORE consulting _redirects, so they are not affected.
/* /en/:splat  200
